# Copy to .env and fill in. Never commit the real .env.
# Run locally with:  node --env-file=.env index.js

# Discord bot token from the Developer Portal (Bot → Reset Token).
DISCORD_BOT_TOKEN=

# Full ingest URL of the main app.
INGEST_URL=https://k-pop-black.vercel.app/api/bot?action=ingest&platform=discord

# Shared secret sent as the x-ingest-secret header. Must match the main app.
INGEST_SECRET=
